add target fixes (ErrorFixes initialFixes) =
    SimpleAssocList.update target
        (\\maybePreviousFixes ->
            case fixes of
                Remove ->
                    Just fixes

                Edit [] ->
                    maybePreviousFixes

                Edit newFixes ->
                    case maybePreviousFixes of
                        Just Remove ->
                            maybePreviousFixes

                        Just (Edit previousFixes_) ->
                            Just (Edit (newFixes ++ previousFixes_))

                        Nothing ->
                            Just fixes
        )
        initialFixes
        |> ErrorFixes


