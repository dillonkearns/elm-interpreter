-- TRANSFORM


{-| Fold over the keys pairs in a dictionary, in order from highest
key to lowest key.
-}
foldr : (Int -> a -> a) -> a -> IntDict v -> a
foldr f acc dict =
    case dict of
        Empty () ->
            acc

        Leaf l ->
            f l.key acc

        Inner i ->
            foldr f (foldr f acc i.right) i.left



