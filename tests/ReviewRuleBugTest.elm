-}
decoder : D.Decoder Name
decoder =
  D.andThen decoderHelp D.string


decoderHelp : String -> D.Decoder Name
decoderHelp string =
  case fromString string of
    Just name ->
      D.succeed name

    Nothing ->
      D.fail "I need a valid package name like \\"elm/core\\""
