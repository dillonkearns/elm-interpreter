type ErrorFixes
    = ErrorFixes (SimpleAssocList FileTarget FixKind)


type FixKind
    = Edit (List Fix)
    | Remove


none : ErrorFixes
none =
    ErrorFixes SimpleAssocList.empty


type FixV2
    = FixV2 FileTarget FixKind


edit : FileTarget -> List Fix -> ErrorFixes
edit target edits =
    SimpleAssocList.singleton target (Edit edits)
        |> ErrorFixes


