-}


import Char
import Json.Decode as D
import Json.Encode as E



-- MODULE


{-| A guaranteed valid Elm module name.
-}
type Name =
  Name String



-- STRINGS


{-| Convert a `Name` to a `String` that works in `elm.json`
-}
toString : Name -> String
toString (Name name) =
