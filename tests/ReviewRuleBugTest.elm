signBit : Int
signBit =
    highestBitSet -1


isBranchingBitSet : KeyPrefix -> Int -> Bool
isBranchingBitSet p n =
    (n
        |> Bitwise.xor signBit
        -- This is a hack that fixes the ordering of keys.
        |> Bitwise.and p.branchingBit
    )
        /= 0



