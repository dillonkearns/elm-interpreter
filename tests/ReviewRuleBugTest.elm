toList (ErrorFixes dict) =
    SimpleAssocList.toList dict


any : (( FileTarget, FixKind ) -> Bool) -> ErrorFixes -> Bool
any isOkay (ErrorFixes dict) =
    SimpleAssocList.toList dict
        |> List.any isOkay


isEmpty : ErrorFixes -> Bool
isEmpty (ErrorFixes dict) =
    SimpleAssocList.isEmpty dict
