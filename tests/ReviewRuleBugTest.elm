    , seed : Int
    , hash : Int
    , charsProcessed : Int
    }


c1 : Int
c1 =
    0xCC9E2D51


c2 : Int
c2 =
    0x1B873593


{-| Takes a seed and a string. Produces a hash (integer).
Given the same seed and string, it will always produce the same hash.

    hashString 1234 "Turn me into a hash" == 4138100590

-}
hashString : Int -> String -> Int
hashString seed str =
