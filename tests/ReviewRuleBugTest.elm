combine : (Node a -> Node b -> c) -> Node a -> Node b -> Node c
combine f ((Node { start } _) as a) ((Node { end } _) as b) =
    Node
        { start = start, end = end }
        (f a b)


{-| Map the value within a node leaving the range untouched
